{
  "id": "elephant.google-keep-import",
  "name": "Import",
  "version": "1.4.0",
  "description": "Imports Google Keep Takeout ZIP archives, extracted folders, web pages and RSS or Atom feeds into scoped local Markdown notes.",
  "author": "Elephant",
  "icon": "download",
  "apiVersion": 1,
  "minAppVersion": "0.18.9",
  "runtime": {
    "type": "javascript-worker",
    "entry": "main.js",
    "mode": "trusted"
  },
  "permissions": {
    "commands": true,
    "settings": true,
    "network": {
      "hosts": ["public-https"]
    },
    "notes": {
      "read": [],
      "write": ["Imported/Google Keep/**", "Sources/**"]
    }
  },
  "contributes": {
    "runtimeMode": "trusted",
    "commands": true,
    "settings": true
  },
  "activationEvents": ["onStartup"]
}
